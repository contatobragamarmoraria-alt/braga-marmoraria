# ============================================
# Braga Marmoraria - Configuração Hostinger
# ============================================

# Forçar tipos MIME corretos para JavaScript e CSS
<IfModule mod_mime.c>
    # JavaScript
    AddType application/javascript .js
    AddType application/javascript .mjs
    AddType text/javascript .js
    
    # CSS
    AddType text/css .css
    
    # JSON
    AddType application/json .json
    
    # Fontes
    AddType font/woff2 .woff2
    AddType font/woff .woff
    AddType font/ttf .ttf
    AddType font/otf .otf
    
    # Imagens
    AddType image/svg+xml .svg
    AddType image/webp .webp
    AddType image/png .png
    AddType image/jpeg .jpg .jpeg
</IfModule>

# Garantir que arquivos .js sejam servidos com charset UTF-8
<IfModule mod_headers.c>
    <FilesMatch "\.(js|css|json)$">
        Header set Content-Type "application/javascript; charset=UTF-8" env=!no_content_type
    </FilesMatch>
    <FilesMatch "\.css$">
        Header set Content-Type "text/css; charset=UTF-8"
    </FilesMatch>
    <FilesMatch "\.json$">
        Header set Content-Type "application/json; charset=UTF-8"
    </FilesMatch>
</IfModule>

# Habilitar rewrite para SPA (Single Page Application)
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /
    
    # Se o arquivo ou diretório existe, sirva diretamente
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    
    # Caso contrário, redirecione para index.html (SPA routing)
    RewriteRule ^ index.html [QSA,L]
</IfModule>

# Habilitar compressão GZIP
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json text/javascript
</IfModule>

# Cache para assets estáticos
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css "access plus 1 year"
    ExpiresByType application/javascript "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"
</IfModule>

# Desabilitar listagem de diretórios
Options -Indexes

# Charset padrão UTF-8
AddDefaultCharset UTF-8
